// =============================================================================
// phase2a/nextflow.config
// -----------------------------------------------------------------------------
// Integration → clustering → annotation for the WT trajectory. Processing
// params live here; the sample roster is the shared params/samples.yml (the
// same single source of truth phase1 and download_geo use). Override any param
// at run time with --<name>.
// =============================================================================

params {
  // --- inputs / outputs (paths relative to this phase2a/ dir) ---
  input_samples = "${projectDir}/../params/samples.yml"     // shared roster
  singlets_dir  = "${projectDir}/../results/phase1"         // phase1 outputs (05_seurat_singlets.rds)
  outdir        = "${projectDir}/../results/phase2a"

  // --- normalization / integration ---
  n_hvgs = 2000
  n_dims = 30

  // --- clustering (resolution locked; the sweep is a script flag, off here) ---
  resolution = 0.4
  algorithm  = 1

  // --- marker DE ---
  top_n_markers = 5
  min_pct       = 0.25
  logfc         = 0.25
}

// --- Provenance: report/timeline/trace/DAG per run -------------------------
report   { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/report.html" }
timeline { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/timeline.html" }
trace    { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/trace.txt" }
dag      { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/dag.html" }

// --- Default process resources ---------------------------------------------
process {
  cpus   = 4
  memory = 16.GB
  // FindAllMarkers exports a large (~13 GB) closure through {future}; extra
  // headroom prevents OOM under the sequential plan the script sets.
  withName: 'MARKERS' { memory = 32.GB }
}

// --- Execution profiles (always pair a compute profile with conda) ---------
//   nextflow run phase2a/main.nf -profile conda,apple_silicon
profiles {

  standard { /* use whatever R is on PATH; no isolation */ }

  conda {
    conda.enabled = true
    process.conda = "/opt/anaconda3/envs/paa-dev"   // existing env (batchelor incl.)
  }

  apple_silicon {                                   // M-series Mac
    process.maxForks = 1                            // fan-in DAG is sequential anyway
  }

  hpc {                                             // SLURM cluster
    process.executor = 'slurm'
    process.queue    = 'main'
    process { cpus = 4; memory = 32.GB }
  }
}

manifest {
  name            = 'paa-dev-trajectory/phase2a'
  description     = 'WT Mesp1-lineage integration (fastMNN) -> clustering -> annotation'
  author          = 'Gideon Obeng'
  nextflowVersion = '>=24.04.0'
}

process.publishDir = [overwrite: true]
