// =============================================================================
// phase1/nextflow.config
// -----------------------------------------------------------------------------
// Global defaults + execution profiles for Phase 1. Per-sample data and any QC
// overrides live in params/samples.yml; this file holds the "how to process"
// defaults (mesp1-style split). Override any param at run time with --<name>.
// =============================================================================

params {
  // --- inputs / outputs (paths are relative to this phase1/ dir) ---
  input_samples = "${projectDir}/../params/samples.yml"   // the roster (read by main.nf)
  raw_data_dir  = "${projectDir}/../raw_data"             // produced by scripts/download_geo.sh
  results_dir   = "${projectDir}/../results/phase1"

  // --- QC defaults (a sample's qc_overrides in samples.yml take precedence) ---
  // Synced with qc_params.defaults in params/samples.yml (May 2026 re-review).
  // mesp1_ko_e95_rep1 overrides to max_features=8000, max_percent_mt=10 — see yml.
  min_features   = 500
  max_features   = 7000   // was 8000; tightened after QC violin review
  max_percent_mt = 5      // was 10;   tightened after QC violin review
  mt_pattern     = "^mt-"     // mouse mitochondrial prefix ("^MT-" for human)
  species        = "mouse"

  // --- normalization + clustering ---
  n_hvgs      = 2000
  n_pcs       = 30
  cluster_res = 0.4

  // --- reproducibility: fixes UMAP / Louvain / SCTransform stochastic steps ---
  seed = 42
}

// --- Provenance: emit a report/timeline/trace/DAG per run -------------------
// Static names (double-quoted so ${params.results_dir} interpolates). We do NOT
// hand-roll a timestamp: the new config parser forbids top-level `def`, and
// overwrite=true keeps the latest run's reports in place.
report   { enabled = true; overwrite = true; file = "${params.results_dir}/pipeline_info/report.html" }
timeline { enabled = true; overwrite = true; file = "${params.results_dir}/pipeline_info/timeline.html" }
trace    { enabled = true; overwrite = true; file = "${params.results_dir}/pipeline_info/trace.txt" }
dag      { enabled = true; overwrite = true; file = "${params.results_dir}/pipeline_info/dag.html" }

// --- Default process resources (raised for the memory-heavy steps) ----------
process {
  cpus   = 2
  memory = 8.GB
  withName: 'DETECT_DOUBLETS'           { memory = 16.GB }   // scDblFinder builds internal PCA/graph
  withName: 'NORMALIZE_DATA'            { memory = 16.GB }   // SCTransform is RAM-hungry
  withName: 'DIM_REDUCTION_AND_CLUSTER' { memory = 16.GB }
}

// --- Execution profiles (always pair a compute profile with conda) ----------
// e.g.  nextflow run phase1/main.nf -profile conda,apple_silicon
profiles {

  standard { /* use whatever R is on PATH; no isolation */ }

  conda {
    conda.enabled  = true
    process.conda  = "/opt/anaconda3/envs/paa-dev" // replaces "${projectDir}/../paa-dev.yml- builds/activates the 'paa-dev' env"
  }

  apple_silicon {                                 // M-series Mac, 32GB+ unified memory
    process.maxForks = 3                          // cap parallel samples to fit RAM
    process { withName: 'NORMALIZE_DATA' { memory = 24.GB } }
  }

  low_mem {                                       // 8–16 GB laptop/desktop
    process.maxForks = 1
    process.memory   = 6.GB
  }

  hpc {                                           // SLURM cluster
    process.executor = 'slurm'
    process.queue    = 'main'
    process { cpus = 4; memory = 32.GB }
  }

  docker {
    docker.enabled    = true
    process.container = 'satijalab/seurat:5.0.0'
  }
}

manifest {
  name            = 'paa-development/phase1'
  description     = 'Per-sample QC, normalization and clustering (Mesp1Cre caudal-arch project)'
  author          = 'Gideon Obeng'
  nextflowVersion = '>=24.04.0'
}
