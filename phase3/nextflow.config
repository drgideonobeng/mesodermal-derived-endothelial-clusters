// phase3/nextflow.config
// -----------------------------------------------------------------------------
// Per-lineage interrogation of the WT Mesp1-lineage atlas.
// Scripts 01 (integrated + uncorrected endothelial embeddings) and 02 (SHF
// module scoring + bed annotation) are orchestrated here. Override any param
// at run time with --<name>.
// -----------------------------------------------------------------------------

params {
  // --- upstream input --------------------------------------------------------
  annotated_obj   = "${projectDir}/../results/phase2/objects/07_annotated.rds"

  // --- outputs ---------------------------------------------------------------
  outdir          = "${projectDir}/../results/phase3"

  // --- lineage namespace (controls output subdirectory structure) ------------
  // results/phase3/<lineage>/integrated/   -- fastMNN beds
  // results/phase3/<lineage>/uncorrected/  -- PCA geometry
  lineage         = "endothelium"

  // --- 01: lineage labels to pull from the frozen `lineage` column ----------
  // Endothelium only: the scientifically correct default; endocardium masked
  // arterial structure in the endo+endocardium run (now archived in subset/).
  lineages_subset = "Endothelium"

  // --- 01: embedding parameters ---------------------------------------------
  n_hvgs          = 2000
  n_dims          = 30
  resolution      = 0.6      // locked from clustree sweep on the endothelial subset
  k_mnn           = 20       // fastMNN nearest neighbours; lower for small subsets
  min_cells_batch = 20       // timepoints with < this n dropped from integration

  // --- 02: SHF module scoring -----------------------------------------------
  focus_bed       = "Arterial_PAA"   // bed within which to test SHF-high vs SHF-low
}

// --- Provenance: report/timeline/trace/DAG per run -------------------------
report   { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/report.html"   }
timeline { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/timeline.html" }
trace    { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/trace.txt"     }
dag      { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/dag.html"      }

// --- Default process resources ---------------------------------------------
process {
  cpus   = 4
  memory = 16.GB
  // FindAllMarkers in 01 exports a large closure through {future}; extra
  // headroom prevents OOM. Both embeddings run in parallel, so peak memory
  // is 2 × this — ensure the machine can accommodate both simultaneously.
  withName: 'SUBSET_INTEGRATED|SUBSET_UNCORRECTED' { memory = 32.GB }
}

// --- Execution profiles (always pair a compute profile with conda) ----------
//   nextflow run phase3/main.nf -profile conda,apple_silicon
profiles {

  standard { /* use whatever R is on PATH; no isolation */ }

  conda {
    conda.enabled = true
    process.conda = "/opt/anaconda3/envs/paa-dev"   // existing env (batchelor incl.)
  }

  apple_silicon {                  // M-series Mac
    // Both SUBSET processes run in parallel; maxForks = 2 allows that.
    // Lower to 1 if memory pressure is a concern (they'll run sequentially).
    process.maxForks = 2
  }

  hpc {                            // SLURM cluster
    process.executor = 'slurm'
    process.queue    = 'main'
    process { cpus = 4; memory = 32.GB }
  }
}

manifest {
  name            = 'mesodermal-derived-endothelial-clusters/phase3'
  description     = 'Endothelial subset (fastMNN + PCA) -> SHF bed annotation + module scoring'
  author          = 'Gideon Obeng'
  nextflowVersion = '>=24.04.0'
}

process.publishDir = [overwrite: true]
